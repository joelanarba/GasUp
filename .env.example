# Copy to .env and fill. NEVER commit .env.

# --- Database (Neon: neon.tech → create project → copy connection string) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- NextAuth ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="changeme"
NEXTAUTH_URL="http://localhost:3000"   # set to your Vercel URL in production

# --- Resend (email) — resend.com → API Keys ---
RESEND_API_KEY="re_xxx"
EMAIL_FROM="GasUp <onboarding@resend.dev>"   # use resend.dev sandbox until domain verified

# --- mNotify (SMS) — mnotify.com → fund account → API key + approved Sender ID ---
MNOTIFY_API_KEY="xxx"
MNOTIFY_SENDER_ID="GasUp"   # must be approved by mNotify (max 11 chars)

# --- Paystack (TEST mode keys only — dashboard.paystack.com → Settings → API Keys) ---
PAYSTACK_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxx"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Cron (daily proactive refill alerts) ---
# Generate: openssl rand -base64 32. Vercel Cron sends this as a Bearer token;
# leave unset locally to allow manual runs of /api/cron/refill-alerts.
CRON_SECRET="changeme"

# --- Seeded admin login (used by the seed script) ---
ADMIN_EMAIL="admin@gasup.app"
ADMIN_PASSWORD="ChangeMe123!"

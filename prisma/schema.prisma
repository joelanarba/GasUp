// GasUp data model.
// Designed around the three differentiators:
//   - Refill history (filledKg + deliveredAt) → prediction engine
//   - Order.verifiedWeightKg + status VERIFYING → trust layer
//   - Pool + Order.poolId → pooled hostel/area refills
// These are relational/aggregate workloads → why Postgres, not Firestore.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  SUPPLIER
  ADMIN
}

enum OrderStatus {
  OPEN         // placed, broadcast to riders — first to accept claims it
  PENDING      // legacy (pre-dispatch); kept to avoid a destructive enum drop
  ACCEPTED     // a rider claimed it
  VERIFYING    // supplier uploaded fill weight, awaiting student confirm
  ON_THE_WAY   // confirmed + en route
  DELIVERED    // dropped off
  COMPLETED    // student closed + (optionally) rated
  CANCELLED
  DISPUTED     // weight mismatch flagged
}

enum CylinderSize {
  KG_3
  KG_6
  KG_12_5
  KG_14_5
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
}

enum PaymentMethod {
  ONLINE
  CASH_ON_DELIVERY
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  phone        String?
  passwordHash String
  fullName     String
  role         Role      @default(STUDENT)
  createdAt    DateTime  @default(now())
  deactivatedAt DateTime? // soft-deactivation (admins): set → can't log in, audit trail preserved

  // student fields
  defaultAddress String?
  defaultLat     Float?
  defaultLng     Float?
  householdSize  Int      @default(1) // seeds the burn-rate model

  // onboarding "gas profile" → powers Day-One prediction before any real refill history
  defaultCylinderSize CylinderSize? // their usual cylinder size
  lastRefillAt        DateTime?     // when they last refilled (their estimate)
  refillSnoozedUntil  DateTime?     // "remind me tomorrow" — mutes the low-gas nudge + cron until then

  // supplier profile (1:1) if role == SUPPLIER
  supplier     Supplier?

  orders       Order[]   @relation("StudentOrders")
  reviews      Review[]
}

model Supplier {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  businessName    String
  vehicleType     String   // Motorbike / Tricycle / Vehicle
  coverageArea    String
  availability    String   @default("AVAILABLE") // AVAILABLE / BUSY / OFFLINE
  ratingAvg       Float    @default(0)
  ratingCount     Int      @default(0)
  pricePerKg      Float    @default(15) // GHS — internal cost (what the rider pays the station); no longer charged to students
  lat             Float?   // rider base location → powers dispatch-board distance
  lng             Float?
  partnerStation  String?  // LPG filling station the rider refills at (optional, shown on the board)
  orders          Order[]
}

model Order {
  id              String       @id @default(cuid())
  student         User         @relation("StudentOrders", fields: [studentId], references: [id])
  studentId       String
  supplier        Supplier?    @relation(fields: [supplierId], references: [id])
  supplierId      String?
  
  // Delivery Location
  address         String
  lat             Float?
  lng             Float?

  cylinderSize    CylinderSize
  requestedKg     Float
  status          OrderStatus  @default(OPEN)
  express         Boolean      @default(false) // premium tier: surcharge + queue priority

  // trust layer
  verifiedWeightKg Float?      // what supplier says they filled
  weightConfirmed  Boolean     @default(false) // student confirmed match
  proofUrl         String?     // weighbridge/scale photo

  // pooling
  poolId          String?
  pool            Pool?        @relation(fields: [poolId], references: [id])
  feeGhs          Float        // pooled orders get a discounted fee

  // payment
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   PaymentMethod @default(ONLINE)
  paystackRef     String?

  specialInstructions String?
  createdAt       DateTime     @default(now())
  deliveredAt     DateTime?    // feeds prediction (days-between-refills)

  review          Review?
}

model Pool {
  id        String   @id @default(cuid())
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  orders    Order[]
}

model Review {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String   @unique
  student     User     @relation(fields: [studentId], references: [id])
  studentId   String
  supplierId  String
  rating      Int      // 1-5
  comment     String?
  createdAt   DateTime @default(now())
}

// Self-service rider onboarding: a public application that an admin approves/rejects.
// Approval creates the User(SUPPLIER)+Supplier; rejection records a reason in notes.
model RiderApplication {
  id             String            @id @default(cuid())
  fullName       String
  email          String
  phone          String?
  businessName   String
  vehicleType    String            // Motorbike / Tricycle / Vehicle
  coverageArea   String
  partnerStation String?
  status         ApplicationStatus @default(PENDING)
  notes          String?           // admin rejection reason / note
  createdAt      DateTime          @default(now())
}

// Audit trail for live external services (mNotify / Resend / Paystack)
model ServiceLog {
  id        String   @id @default(cuid())
  service   String   // "mnotify" | "resend" | "paystack"
  action    String
  success   Boolean
  detail    String?
  createdAt DateTime @default(now())
}
